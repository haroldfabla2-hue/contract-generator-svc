# GLM API Key (from Z.ai / BigModel)
# Also accepts ZAI_API_KEY as fallback
GLM_API_KEY=your_glm_api_key_here

# Mercado Pago Access Token (from https://www.mercadopago.com/developers)
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token_here

# PayPal Credentials (from https://developer.paypal.com/dashboard/applications)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_SECRET=your_paypal_secret_here
# Use sandbox URL for testing, production for live
# PAYPAL_API_URL=https://api-m.sandbox.paypal.com
# PAYPAL_API_URL=https://api-m.paypal.com
